# ~/.aliases - Shared shell aliases
# Managed by dotfiles installer

# =============================================================================
# NAVIGATION
# =============================================================================

alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'
alias ~='cd ~'
alias -- -='cd -'

# Directory shortcuts
alias dl='cd ~/Downloads'
alias dt='cd ~/Desktop'
alias dc='cd ~/Documents'
alias dev='cd ~/dev'
alias proj='cd ~/projects'
alias dot='cd ~/.dotfiles'

# =============================================================================
# LISTING
# =============================================================================

# Detect best ls alternative
if command -v eza &> /dev/null; then
    alias ls='eza --color=auto --icons --group-directories-first'
    alias ll='eza -la --icons --group-directories-first'
    alias la='eza -a --icons --group-directories-first'
    alias lt='eza -la --icons --sort=modified'
    alias lS='eza -la --icons --sort=size'
    alias tree='eza --tree --icons'
elif command -v exa &> /dev/null; then
    alias ls='exa --color=auto --icons --group-directories-first'
    alias ll='exa -la --icons --group-directories-first'
    alias la='exa -a --icons --group-directories-first'
    alias lt='exa -la --icons --sort=modified'
    alias lS='exa -la --icons --sort=size'
    alias tree='exa --tree --icons'
else
    alias ls='ls --color=auto'
    alias ll='ls -alF'
    alias la='ls -A'
    alias lt='ls -altr'
    alias lS='ls -alS'
fi

alias l='ls -CF'
alias lh='ll -h'
alias l.='ls -d .*'         # Hidden files only

# =============================================================================
# FILE OPERATIONS
# =============================================================================

# Safety first
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'
alias ln='ln -i'

# Verbose operations
alias mkdir='mkdir -pv'
alias rmdir='rmdir -v'

# Better defaults
if command -v bat &> /dev/null; then
    alias cat='bat --paging=never'
    alias less='bat'
fi

# =============================================================================
# GREP & SEARCH
# =============================================================================

alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# Use ripgrep if available
if command -v rg &> /dev/null; then
    alias rg='rg --smart-case'
fi

# Find shortcuts
alias ff='find . -type f -name'
alias fd='find . -type d -name'

# =============================================================================
# DISK & SYSTEM
# =============================================================================

alias df='df -h'
alias du='du -h'
alias duf='du -sh * | sort -h'
alias dus='du -sh'
alias free='free -h'

# Process management
alias ps='ps auxf'
alias psg='ps aux | grep -v grep | grep -i'
alias top='htop 2>/dev/null || top'

# Memory
alias meminfo='free -h -l -t'
alias psmem='ps auxf | sort -nr -k 4 | head -10'
alias pscpu='ps auxf | sort -nr -k 3 | head -10'

# =============================================================================
# NETWORK
# =============================================================================

alias ports='netstat -tulanp 2>/dev/null || ss -tulanp'
alias listening='netstat -an | grep LISTEN'
alias myip='curl -s ifconfig.me'
alias localip="hostname -I 2>/dev/null | awk '{print \$1}' || ipconfig getifaddr en0"
alias ips="ifconfig -a | grep -o 'inet6\\? \\(addr:\\)\\?\\s\\?\\(\\(\\([0-9]\\+\\.\\)\\{3\\}[0-9]\\+\\)\\|[a-fA-F0-9:]\\+\\)' | awk '{ sub(/inet6? (addr:)? ?/, \"\"); print }'"
alias ping='ping -c 5'
alias fastping='ping -c 100 -s 1'

# Download
alias wget='wget -c'

