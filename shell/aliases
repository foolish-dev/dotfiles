# =============================================================================
# NODE / NPM
# =============================================================================

alias ni='npm install'
alias nid='npm install --save-dev'
alias nig='npm install -g'
alias nr='npm run'
alias ns='npm start'
alias nt='npm test'
alias nb='npm run build'
alias nrd='npm run dev'

# Yarn
alias y='yarn'
alias ya='yarn add'
alias yad='yarn add --dev'
