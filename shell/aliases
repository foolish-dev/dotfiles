# =============================================================================
# PYTHON
# =============================================================================

alias py='python3'
alias python='python3'
alias pip='pip3'
alias venv='python3 -m venv'
alias activate='source venv/bin/activate'
alias deact='deactivate'
alias pipr='pip install -r requirements.txt'
