#!/usr/bin/env bash
# colorbars -- display colored bars
printf '\n'
for i in {0..7}; do
  printf '\e[48;5;%sm        \e[0m' "$i"
done
printf '\n'
for i in {8..15}; do
  printf '\e[48;5;%sm        \e[0m' "$i"
done
printf '\n\n'
for i in {0..255}; do
  printf '\e[48;5;%sm \e[0m' "$i"
  (( (i + 1) % 16 == 0 )) && printf '\n'
done
printf '\n'
