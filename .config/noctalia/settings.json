{
    "bar": {
        "position": "top",
        "height": 34,
        "widgetSpacing": 6,
        "contentPadding": 2,
        "fontScale": 1,
        "enableExclusionZoneInset": true,
        "backgroundOpacity": 0.88,
        "useSeparateOpacity": false,
        "floating": true,
        "marginVertical": 4,
        "marginHorizontal": 4,
        "frameThickness": 8,
        "showOnAllMonitors": true
    },
    "general": {
        "animationSpeed": 1.2,
        "radiusRatio": 1.0,
        "hapticFeedback": false,
        "screenCornerRadius": 12
    },
    "colorSchemes": {
        "darkMode": true,
        "useWallpaperColors": false,
        "customColorScheme": "dark-hacker"
    },
    "dock": {
        "enabled": true,
        "position": "bottom",
        "autoHide": true,
        "iconSize": 48,
        "backgroundOpacity": 0.85,
        "floating": true
    },
    "notifications": {
        "position": "top-right",
        "maxVisible": 4,
        "timeout": 5000
    },
    "appLauncher": {
        "useApp2Unit": false,
        "showRecentApps": true,
        "maxRecentApps": 8
    },
    "overview": {
        "enableOverviewWallpaper": true,
        "showWorkspaceLabels": true
    },
    "wallpaper": {
        "enableOverviewWallpaper": true,
        "enableWallpaperColors": false
    },
    "lockScreen": {
        "enabled": true,
        "showClock": true,
        "clockFormat": "24h"
    },
    "osd": {
        "enabled": true,
        "position": "bottom",
        "showProgressBar": true
    },
    "controlCenter": {
        "showQuickSettings": true,
        "showMediaPlayer": true,
        "showCalendar": true,
        "showNotifications": true
    }
}
