# =============================================================================
# Git Config -- Coding Workstation
# Tracked file. Deployed to ~/.config/git/dotfiles.config (NOT ~/.gitconfig)
# so that `git config --global ...` lands in the untracked stub at
# ~/.gitconfig instead of mutating this file.
# =============================================================================
#
# Layout (after `./deploy.sh`):
#
#   ~/.gitconfig                       (untracked stub, generated)
#     [include] ~/.config/git/dotfiles.config   -> this file
#     [include] ~/.gitconfig.local              -> identity + signing
#
#   ~/.config/git/dotfiles.config      (symlink -> $DOTFILES/.gitconfig)
#   ~/.gitconfig.local                 (untracked, generated by deploy.sh)
#
# Identity, signingkey, commit.gpgsign live in ~/.gitconfig.local. If it is
# missing, commits will fail until you create it:
#   git config --file ~/.gitconfig.local user.name  "Your Name"
#   git config --file ~/.gitconfig.local user.email "you@example.com"
#
# DO NOT add [user] or commit.gpgsign here -- they are per-machine.

[init]
    defaultBranch = main

[core]
    editor = nvim
    pager = delta
    autocrlf = input
    whitespace = trailing-space,space-before-tab
    excludesFile = ~/.gitignore_global
    fsmonitor = true
    untrackedCache = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    side-by-side = true
    line-numbers = true
    syntax-theme = tokyonight_night
    file-style = bold yellow ul
    hunk-header-style = omit
    minus-style = syntax "#3a1e2e"
    minus-emph-style = syntax "#5c2940"
    plus-style = syntax "#1e3a2e"
    plus-emph-style = syntax "#2a5c3f"

[merge]
    conflictstyle = zdiff3
    tool = nvimdiff

[mergetool "nvimdiff"]
    cmd = nvim -d $LOCAL $REMOTE $MERGED -c 'wincmd J'

[diff]
    algorithm = histogram
    colorMoved = default
    tool = nvimdiff

[difftool "nvimdiff"]
    cmd = nvim -d $LOCAL $REMOTE

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true
    followTags = true

[fetch]
    prune = true
    pruneTags = true

[rebase]
    autoStash = true
    autoSquash = true

[rerere]
    enabled = true

[branch]
    sort = -committerdate

[tag]
    sort = -version:refname

[column]
    ui = auto

[color]
    ui = true

[color "branch"]
    current = yellow bold
    local = green
    remote = cyan

[color "status"]
    added = green
    changed = yellow
    untracked = red

# ── Aliases ────────────────────────────────────────────────────────────────
[alias]
    # Status / log
    s   = status -sb
    l   = log --oneline --graph --decorate -20
    la  = log --oneline --graph --decorate --all
    ll  = log --pretty=format:'%C(yellow)%h%Creset %C(cyan)%ad%Creset %C(green)%an%Creset %s%C(auto)%d' --date=short -20
    today = "!git log --oneline --since='midnight' --author=\"$(git config user.name)\""

    # Branching
    co  = checkout
    cb  = checkout -b
    br  = branch -vv
    bra = branch -a -vv
    bd  = branch -d
    bD  = branch -D
    main = checkout main
    dev  = checkout dev

    # Staging / committing
    a   = add
    aa  = add -A
    ap  = add -p
    c   = commit
    cm  = commit -m
    ca  = commit --amend --no-edit
    cam = commit --amend
    cf  = commit --fixup
    wip = !git add -A && git commit -m 'wip: work in progress'

    # Push / pull
    p   = push
    pf  = push --force-with-lease
    pl  = pull --rebase
    f   = fetch --all --prune

    # Diff
    d   = diff
    ds  = diff --staged
    dt  = difftool
    dts = difftool --staged

    # Stash
    ss  = stash
    sp  = stash pop
    sl  = stash list
    sd  = stash drop

    # Reset / clean
    unstage = reset HEAD --
    undo    = reset --soft HEAD~1
    nuke    = !git reset --hard HEAD && git clean -fd
    wipe    = !git add -A && git commit -qm 'WIPE SAVEPOINT' && git reset HEAD~1 --hard

    # Search
    grep  = grep -Ii
    find  = !git ls-files | grep -i

    # Utility
    aliases  = config --get-regexp alias
    whoami   = !git config user.name && git config user.email
    root     = rev-parse --show-toplevel
    upstream = !git rev-parse --abbrev-ref --symbolic-full-name @{u}
    contrib  = shortlog -sne
    fresh    = !git fetch --all --prune && git rebase origin/main
    sync     = !git fetch --all --prune && git pull --rebase && git push
    cloc     = !git ls-files -z | xargs -0 wc -l 2>/dev/null | tail -1

    # Interactive rebase last N commits
    reb = "!f() { git rebase -i HEAD~${1:-5}; }; f"

    # Create a patch from staged changes
    patch = format-patch --stdout HEAD~1

    # Show file at specific commit
    show-file = "!f() { git show \"$1:$2\"; }; f"

[commit]
    verbose = true
    # gpgsign is opt-in: set in ~/.gitconfig.local once you have a signing
    # key configured + ~/.ssh/allowed_signers populated. Enabling it here
    # unconditionally would block new users from committing.
    # gpgsign = true

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = ~/.ssh/allowed_signers

[url "git@github.com:"]
    insteadOf = gh:

[url "git@gitlab.com:"]
    insteadOf = gl:

[credential]
    helper = /usr/lib/git-core/git-credential-libsecret
